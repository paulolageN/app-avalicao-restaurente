<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF9800"
    android:orientation="vertical"
    tools:context=".CadastroDeRestauranteActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:layout_weight="0.1"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgVoltar"
            android:layout_width="61dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="300dp"
            android:layout_weight="1"
            app:srcCompat="@drawable/arrow_back_36dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:layout_marginRight="30dp"
        android:layout_weight="0.1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AvaliaFood"
            android:textColor="#373434"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalhes do Restaurante"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="4"
        android:background="@drawable/background_rounded_left"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="10dp"
                    android:layout_weight="0.1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtNomeRestaurante"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nome: "
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/txtEnderecoRestaurante"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Endereco;"
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/txtTelefone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Telefone: "
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/txtDescricaoRestaurante"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Descricao: "
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/txtHorarioRestaurante"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horario de Funcionamento: "
                        android:textColor="#000000" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="0.1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:text="Avaliacoes"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ListView
                        android:id="@+id/Avaliacoes"
                        android:layout_width="match_parent"
                        android:layout_height="429dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</LinearLayout>
